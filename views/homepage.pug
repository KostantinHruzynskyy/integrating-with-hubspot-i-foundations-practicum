doctype html
html(lang="en")
  head
    title= title
    link(rel="stylesheet", href="/css/style.css")
  body
    h1 Custom Object Records
    a(href="/update-cobj") Add to this table

    table
      thead
        tr
          each prop in properties
            th= prop
      tbody
        each record in records
          tr
            each prop in properties
              td= record.properties[prop]
